{
  "name": "xiri",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --watch --port 4301 --host localhost --hmr demo",
    "build": "ng build --configuration production xiri-ng",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "version": "cd projects/xiri-ng && npm version patch",
    "demo": "ng serve --watch --port 4301 --ssl --hmr --host 0.0.0.0 demo",
    "package": "npm run version && npm run build xiri-ng && cd dist/xiri-ng && npm pack",
    "publish": "./release.sh"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.2",
    "@angular/cdk": "^21.2.1",
    "@angular/common": "^21.2.2",
    "@angular/compiler": "^21.2.2",
    "@angular/core": "^21.2.2",
    "@angular/forms": "^21.2.2",
    "@angular/material": "^21.2.1",
    "@angular/material-date-fns-adapter": "^21.2.1",
    "@angular/platform-browser": "^21.2.2",
    "@angular/platform-browser-dynamic": "^21.2.2",
    "@angular/router": "^21.2.2",
    "@date-fns/tz": "^1.4.1",
    "@fontsource-utils/scss": "^0.2.2",
    "@fontsource/roboto": "^5.2.9",
    "date-fns": "^4.1.0",
    "material-symbols": "^0.40",
    "ngx-mat-select-search": "^8.0.4",
    "rxjs": "^7.8.1",
    "tslib": "^2.5.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.2",
    "@angular/language-service": "^21.2.2",
    "echarts": "^6.0.0",
    "jsdom": "^28.1.0",
    "ng-packagr": "^21.0.0",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
